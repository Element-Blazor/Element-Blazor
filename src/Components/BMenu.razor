@inherits BMenuContainer
<CascadingValue Value=this>
    <CascadingValue Value="Options">
        <ul role="menubar" class="@menuClass" style="@menuStyle" @onmouseout:stopPropagation @onkeydown="OnKeyDownAsync" @ref="Container" tabindex="0" aria-orientation="@(Mode == MenuMode.Horizontal ? "horizontal" : "vertical")">@ChildContent</ul>
    </CascadingValue>
</CascadingValue>
