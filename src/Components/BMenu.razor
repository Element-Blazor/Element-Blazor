@inherits BMenuContainer
<CascadingValue Value=this>
    <CascadingValue Value="Options">
        <ul role="menubar" class="@modeClass el-menu" style="overflow:auto;@Style" @onmouseout:stopPropagation @onkeydown="OnKeyDownAsync" @ref="Container">@ChildContent</ul>
    </CascadingValue>
</CascadingValue>
